<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F4F1">

    <!-- header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1B1B19"
        android:paddingStart="14dp"
        android:paddingEnd="6dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp">

        <TextView
            android:id="@+id/brand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="UNBOUND"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.18" />

        <TextView
            android:id="@+id/weeks_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2w"
            android:textColor="#8C8C88"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:paddingEnd="8dp" />

        <ImageButton
            android:id="@+id/btn_refresh"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:padding="6dp"
            android:src="@drawable/ic_refresh"
            android:background="@android:color/transparent"
            android:contentDescription="Refresh" />

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:padding="6dp"
            android:src="@drawable/ic_settings"
            android:background="@android:color/transparent"
            android:contentDescription="Settings" />
    </LinearLayout>

    <!-- day-of-week strip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#F4F4F1"
        android:paddingTop="5dp"
        android:paddingBottom="3dp">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="SUN" android:textSize="9sp" android:fontFamily="monospace" android:textColor="#A8A29E" android:letterSpacing="0.08" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="MON" android:textSize="9sp" android:fontFamily="monospace" android:textColor="#A8A29E" android:letterSpacing="0.08" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="TUE" android:textSize="9sp" android:fontFamily="monospace" android:textColor="#A8A29E" android:letterSpacing="0.08" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="WED" android:textSize="9sp" android:fontFamily="monospace" android:textColor="#A8A29E" android:letterSpacing="0.08" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="THU" android:textSize="9sp" android:fontFamily="monospace" android:textColor="#A8A29E" android:letterSpacing="0.08" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="FRI" android:textSize="9sp" android:fontFamily="monospace" android:textColor="#A8A29E" android:letterSpacing="0.08" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="SAT" android:textSize="9sp" android:fontFamily="monospace" android:textColor="#A8A29E" android:letterSpacing="0.08" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ListView
            android:id="@+id/week_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@null"
            android:dividerHeight="0dp"
            android:scrollbars="none" />

        <TextView
            android:id="@+id/empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="24dp"
            android:text="Open Unbound once to grant calendar access."
            android:textColor="#78716C"
            android:textSize="13sp" />
    </FrameLayout>
</LinearLayout>
