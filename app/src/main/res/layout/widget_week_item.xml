<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <ImageView
        android:id="@+id/week_img"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:scaleType="fitCenter"
        android:contentDescription="Week" />

    <!-- per-day tap zones (FrameLayouts: plain View isn't allowed in widgets) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <FrameLayout android:id="@+id/tap0" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
        <FrameLayout android:id="@+id/tap1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
        <FrameLayout android:id="@+id/tap2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
        <FrameLayout android:id="@+id/tap3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
        <FrameLayout android:id="@+id/tap4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
        <FrameLayout android:id="@+id/tap5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
        <FrameLayout android:id="@+id/tap6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
    </LinearLayout>
</FrameLayout>
