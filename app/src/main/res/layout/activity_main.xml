<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F4F1">

    <!-- header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="6dp">

        <TextView
            android:id="@+id/month_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="July 2026"
            android:textColor="#F4F5F7"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/brand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textSize="10sp" />

        <LinearLayout
            android:id="@+id/seg_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="2dp">

            <TextView
                android:id="@+id/seg_weeks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:text="Weeks"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/seg_agenda"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:text="Agenda"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_today"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Today"
            android:textSize="12sp"
            android:background="@android:color/transparent" />

        <ImageButton
            android:id="@+id/btn_app_settings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_settings"
            android:background="@android:color/transparent"
            android:contentDescription="Settings" />
    </LinearLayout>

    <!-- day-of-week strip -->
    <LinearLayout
        android:id="@+id/dow_strip"
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:orientation="horizontal">

        <TextView android:id="@+id/dow0" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="SUN" android:textSize="10sp" android:fontFamily="monospace" android:textColor="#A8A29E" android:letterSpacing="0.08" />
        <TextView android:id="@+id/dow1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="MON" android:textSize="10sp" android:fontFamily="monospace" android:textColor="#A8A29E" android:letterSpacing="0.08" />
        <TextView android:id="@+id/dow2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="TUE" android:textSize="10sp" android:fontFamily="monospace" android:textColor="#A8A29E" android:letterSpacing="0.08" />
        <TextView android:id="@+id/dow3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="WED" android:textSize="10sp" android:fontFamily="monospace" android:textColor="#A8A29E" android:letterSpacing="0.08" />
        <TextView android:id="@+id/dow4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="THU" android:textSize="10sp" android:fontFamily="monospace" android:textColor="#A8A29E" android:letterSpacing="0.08" />
        <TextView android:id="@+id/dow5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="FRI" android:textSize="10sp" android:fontFamily="monospace" android:textColor="#A8A29E" android:letterSpacing="0.08" />
        <TextView android:id="@+id/dow6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="SAT" android:textSize="10sp" android:fontFamily="monospace" android:textColor="#A8A29E" android:letterSpacing="0.08" />
    </LinearLayout>

    <!-- the calendar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ListView
            android:id="@+id/app_weeks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@null"
            android:dividerHeight="0dp"
            android:scrollbars="none" />

        <!-- onboarding / settings panel -->
        <ScrollView
            android:id="@+id/panel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:background="#F4F4F1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#44403C"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:text="" />

                <Button
                    android:id="@+id/btn_grant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Grant calendar access"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#1B1B19" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CALENDARS"
                    android:textColor="#A8A29E"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="26dp" />

                <LinearLayout
                    android:id="@+id/cal_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="6dp" />

                <!-- THEME -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="THEME"
                    android:textColor="#A8A29E"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="26dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <Button android:id="@+id/app_th_auto" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:text="Auto" />
                    <Button android:id="@+id/app_th_light" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:text="Light" />
                    <Button android:id="@+id/app_th_dark" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Dark" />
                </LinearLayout>

                <!-- OPACITY -->
                <TextView
                    android:id="@+id/app_opacity_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WIDGET OPACITY — 100%"
                    android:textColor="#A8A29E"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="24dp" />

                <SeekBar
                    android:id="@+id/app_opacity_seek"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:max="80"
                    android:progress="80" />

                <!-- TEXT SIZE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TEXT SIZE"
                    android:textColor="#A8A29E"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="24dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <Button android:id="@+id/app_tx_s" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:text="Small" />
                    <Button android:id="@+id/app_tx_m" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:text="Medium" />
                    <Button android:id="@+id/app_tx_l" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Large" />
                </LinearLayout>

                <!-- OPTIONS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OPTIONS"
                    android:textColor="#A8A29E"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="24dp" />

                <Switch
                    android:id="@+id/app_sw_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Show widget header"
                    android:textSize="15sp" />

                <Switch
                    android:id="@+id/app_sw_monday"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Start week on Monday"
                    android:textSize="15sp" />

                <Switch
                    android:id="@+id/app_sw_strike"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Strike through finished days"
                    android:textSize="15sp" />

                <!-- WIDGET LAYOUT (applies to all placed widgets) -->
                <TextView
                    android:id="@+id/app_widget_hdr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WIDGET LAYOUT — ALL WIDGETS"
                    android:textColor="#A8A29E"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="24dp" />

                <LinearLayout
                    android:id="@+id/app_widget_mode_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <Button android:id="@+id/app_md_weeks" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:text="Weeks grid" />
                    <Button android:id="@+id/app_md_agenda" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Agenda (30 days)" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/app_widget_weeks_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">

                    <Button android:id="@+id/app_wk1" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:text="1" />
                    <Button android:id="@+id/app_wk2" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:text="2" />
                    <Button android:id="@+id/app_wk3" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:text="3" />
                    <Button android:id="@+id/app_wk4" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="4" />
                </LinearLayout>

                <TextView
                    android:id="@+id/app_version_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:text="Unbound"
                    android:textColor="#A8A29E"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.04" />

                <Button
                    android:id="@+id/btn_close_panel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Done"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#1B1B19" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>
</LinearLayout>
