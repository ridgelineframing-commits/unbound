<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F4F1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="26dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RIDGELINE CONSTRUCTION"
            android:textColor="#A8A29E"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.14"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unbound"
            android:textColor="#1B1B19"
            android:textSize="34sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No more tiny boxes."
            android:textColor="#57534E"
            android:textSize="15sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textColor="#44403C"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:text="" />

        <Button
            android:id="@+id/btn_grant"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Grant calendar access"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1B1B19" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CALENDARS"
            android:textColor="#A8A29E"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:layout_marginTop="28dp" />

        <LinearLayout
            android:id="@+id/cal_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="6dp" />

    </LinearLayout>
</ScrollView>
